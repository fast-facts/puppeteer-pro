{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "lib": [
      "ES2018",
      "dom"
    ],
    "types": [
      "node"
    ],
    "module": "commonjs",
    "target": "ES2018",
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "importHelpers": true,
    "inlineSources": true,
    "noEmitHelpers": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "pretty": true,
    "sourceMap": true,
    "strict": true,
    "strictBindCallApply": false
  },
  "include": [
    "./src/*.ts"
  ]
}