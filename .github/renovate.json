{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "minimumReleaseAge": "14 days",
    "schedule": [
        "before 4am"
    ],
    "timezone": "America/New_York",
    "prCreation": "immediate",
    "labels": [
        "dependencies"
    ],
    "rangeStrategy": "bump",
    "automerge": true,
    "automergeType": "pr",
    "packageRules": [
        {
            "matchManagers": [
                "github-actions"
            ],
            "matchDepTypes": [
                "uses-with"
            ],
            "matchDepNames": [
                "node"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "enabled": false
        },
        {
            "matchDepTypes": [
                "engines"
            ],
            "matchPackageNames": [
                "node"
            ],
            "enabled": false
        },
        {
            "groupName": "typescript and eslint",
            "matchPackageNames": [
                "/*typescript*/",
                "/*eslint*/"
            ]
        },
        {
            "groupName": "jest",
            "matchPackageNames": [
                "/*jest*/"
            ]
        },
        {
            "groupName": "types",
            "matchPackageNames": [
                "/@types/*/",
                "!/*jest*/"
            ]
        },
        {
            "groupName": "user-agents",
            "matchPackageNames": [
                "user-agents"
            ],
            "schedule": [
                "on the first day of the month"
            ]
        }
    ]
}
